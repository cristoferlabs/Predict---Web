# Supabase (obtener en: supabase.com → tu proyecto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# URL base de la app (para llamadas server-side a las API routes)
# En desarrollo: http://localhost:3000
# En producción: https://predict-web-ruddy.vercel.app
NEXT_PUBLIC_BASE_URL=https://predict-web-ruddy.vercel.app

# Power BI Embed (obtener en: app.powerbi.com → tu reporte → File → Embed report → Website or portal)
NEXT_PUBLIC_POWERBI_EMBED_URL=https://app.powerbi.com/reportEmbed?reportId=...
