      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-brutalist-heading { font-family: 'Space Grotesk', sans-serif; }\n  .font-brutalist-mono { font-family: 'IBM Plex Mono', monospace; }\n\n  .noise-bg {\n    background-image: url('https://images.unsplash.com/photo-1602475063211-3d98d60e3b1f?auto=format&w=1440&q=80&fit=crop');\n    background-blend-mode: overlay;\n  }\n\n  /* Segments for charts */\n  .segment-bar {\n    display: flex;\n    gap: 2px;\n  }\n  .segment {\n    height: 12px;\n    width: 4px;\n    background-color: #232830;\n  }\n  .segment.active {\n    background-color: #4f95d6;\n  }\n  .segment.success {\n    background-color: #34d399;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#0a0c0f] text-white font-brutalist-mono noise-bg flex\" data-kid=\"1\">\n  \n  <aside class=\"w-16 md:w-64 border-r-4 border-[#232830] flex flex-col shrink-0\" data-kid=\"2\">\n    <div class=\"p-6 border-b-4 border-[#232830]\" data-kid=\"3\">\n      <h1 class=\"font-brutalist-heading text-2xl font-bold tracking-tighter uppercase leading-none\" data-kid=\"4\">\n        Tactical<br data-kid=\"5\">Report\n      </h1>\n      <div class=\"mt-2 text-[10px] text-[#4f95d6] font-bold\" data-kid=\"6\">[ SYSTEM_v4.2 ]</div>\n    </div>\n    \n    <nav class=\"flex-1 overflow-y-auto\" data-kid=\"7\">\n      <div class=\"p-6 space-y-8\" data-kid=\"8\">\n        <div data-kid=\"9\">\n          <div class=\"text-[10px] text-gray-500 uppercase font-bold mb-4 tracking-widest\" data-kid=\"10\">TEMPORAL_MARKER</div>\n          <div class=\"space-y-2\" data-kid=\"11\">\n            <button class=\"w-full text-left p-3 border-2 border-[#4f95d6] bg-[#4f95d6]/10 text-white font-bold text-sm\" data-kid=\"12\">\n              20 JUN 2026\n            </button>\