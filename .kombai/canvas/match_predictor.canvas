      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-main: #0a0c0f;\n    --bg-card: #14171c;\n    --bg-alt: #0d1015;\n    --border: #232830;\n    --accent-blue: #3aa0ff;\n    --accent-green: #34d399;\n    --accent-yellow: #fbbf24;\n    --accent-red: #f87171;\n    --text-primary: #f3f5f7;\n    --text-secondary: #94a3b8;\n  }\n\n  body {\n    background-color: var(--bg-main);\n    color: var(--text-primary);\n    font-family: 'Public Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-mono {\n    font-family: 'IBM Plex Mono', monospace;\n  }\n\n  .glow-blue {\n    text-shadow: 0 0 8px rgba(58, 160, 255, 0.6);\n  }\n\n  .glow-green {\n    text-shadow: 0 0 8px rgba(52, 211, 153, 0.6);\n  }\n\n  .border-glow-blue {\n    box-shadow: 0 0 15px rgba(58, 160, 255, 0.2);\n    border-color: var(--accent-blue);\n  }\n\n  /* Ticker Animation */\n  @keyframes ticker {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .ticker-scroll {\n    display: flex;\n    width: max-content;\n    animation: ticker 30s linear infinite;\n  }\n\n  .isometric-grid {\n    background-image: \n      linear-gradient(30deg, #1c2127 12%, transparent 12.5%, transparent 87%, #1c2127 87.5%, #1c2127),\n      linear-gradient(150deg, #1c2127 12%, transparent 12.5%, transparent 87%, #1c2127 87.5%, #1c2127),\n      linear-gradient(30deg, #1c2127 12%, transparent 12.5%, transparent 87%, #1c2127 87.5%, #1c2127),\n      linear-gradient(150deg, #1c2127 12%, transparent 12.5%, transparent 87%, #1c2127 87.5%, #1c2127),\n      linear-gradient(60deg, #232830 25%, transparent 25.5%, transparent 75%, #232830 75%, #232830),\n      linear-gradient(60deg, #232830 25%, transparent 25.5%, transparent 75%, #232830 75%, #232830);\n    background-size: 80px 140px;\n    background-position: 0 0, 0 0, 40px 70px, 40px 70px, 0 0, 40px 70px;\n    opacity: 0.03;\n    pointer-events: none;\n    position: fixed;\n    inset: 0;\n    z-index: 0;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--bg-main);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: var(--border);\n    border-radius: 3px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: var(--accent-blue);\n  }\n</style>\n\n<div class=\"relative min-h-screen z-10\" data-kid=\"1\">\n  <div class=\"isometric-grid\" data-kid=\"2\"></div>\n\n  \n  <div class=\"w-full bg-black/80 border-b border-[var(--border)] h-8 flex items-center overflow-hidden z-50 sticky top-0 backdrop-blur-sm\" data-kid=\"3\">\n    <div class=\"ticker-scroll font-mono text-[10px] uppercase tracking-wider space-x-8 px-4\" data-kid=\"4\">\n      <div class=\"flex items-center space-x-2\" data-kid=\"5\">\n        <span class=\"w-1.5 h-1.5 bg-[var(--accent-green)] rounded-full animate-pulse shadow-[0_0_8px_var(--accent-green)]\" data-kid=\"6\"></span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"7\">PL:</span>\n        <span data-kid=\"8\">ARS 2 - 1 CHE</span>\n        <span class=\"text-[var(--accent-blue)]\" data-kid=\"9\">72'</span>\n      </div>\n      <div class=\"flex items-center space-x-2\" data-kid=\"10\">\n        <span class=\"w-1.5 h-1.5 bg-[var(--accent-green)] rounded-full animate-pulse shadow-[0_0_8px_var(--accent-green)]\" data-kid=\"11\"></span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"12\">LL:</span>\n        <span data-kid=\"13\">RMA 0 - 0 BAR</span>\n        <span class=\"text-[var(--accent-blue)]\" data-kid=\"14\">15'</span>\n      </div>\n      <div class=\"flex items-center space-x-2\" data-kid=\"15\">\n        <span class=\"w-1.5 h-1.5 bg-[var(--accent-red)] rounded-full shadow-[0_0_4px_var(--accent-red)]\" data-kid=\"16\"></span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"17\">SA:</span>\n        <span data-kid=\"18\">INT 3 - 0 JUV</span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"19\">FT</span>\n      </div>\n      <div class=\"flex items-center space-x-2\" data-kid=\"20\">\n        <span class=\"w-1.5 h-1.5 bg-[var(--accent-green)] rounded-full animate-pulse\" data-kid=\"21\"></span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"22\">BUN:</span>\n        <span data-kid=\"23\">BAY 1 - 1 DOR</span>\n        <span class=\"text-[var(--accent-blue)]\" data-kid=\"24\">HT</span>\n      </div>\n      \n      <div class=\"flex items-center space-x-2\" data-kid=\"25\">\n        <span class=\"w-1.5 h-1.5 bg-[var(--accent-green)] rounded-full animate-pulse\" data-kid=\"26\"></span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"27\">PL:</span>\n        <span data-kid=\"28\">LIV 1 - 0 MCI</span>\n        <span class=\"text-[var(--accent-blue)]\" data-kid=\"29\">55'</span>\n      </div>\n      <div class=\"flex items-center space-x-2\" data-kid=\"30\">\n        <span class=\"w-1.5 h-1.5 bg-[var(--accent-green)] rounded-full animate-pulse\" data-kid=\"31\"></span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"32\">PL:</span>\n        <span data-kid=\"33\">ARS 2 - 1 CHE</span>\n        <span class=\"text-[var(--accent-blue)]\" data-kid=\"34\">72'</span>\n      </div>\n      <div class=\"flex items-center space-x-2\" data-kid=\"35\">\n        <span class=\"w-1.5 h-1.5 bg-[var(--accent-green)] rounded-full animate-pulse\" data-kid=\"36\"></span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"37\">LL:</span>\n        <span data-kid=\"38\">RMA 0 - 0 BAR</span>\n        <span class=\"text-[var(--accent-blue)]\" data-kid=\"39\">15'</span>\n      </div>\n      <div class=\"flex items-center space-x-2\" data-kid=\"40\">\n        <span class=\"w-1.5 h-1.5 bg-[var(--accent-red)] rounded-full\" data-kid=\"41\"></span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"42\">SA:</span>\n        <span data-kid=\"43\">INT 3 - 0 JUV</span>\n        <span class=\"text-[var(--text-secondary)]\" data-kid=\"44\">FT</span>\n      </div>\n    </div>\n  </div>\n\n  \n  <nav class=\"bg-[var(--bg-main)] border-b border-[var(--border)] px-6 py-3 flex items-center justify-between sticky top-8 z-40 backdrop-blur-md bg-opacity-90\" data-kid=\"45\">\n    <div class=\"flex items-center space-x-8\" data-kid=\"46\">\n      <div class=\"flex items-center space-x-3\" data-kid=\"47\">\n        <div class=\"w-8 h-8 bg-gradient-to-br from-[var(--accent-blue)] to-blue-700 flex items-center justify-center rounded-sm\" data-kid=\"48\">\n          <i class=\"ti ti-chart-arrows text-white text-xl\" data-kid=\"49\"></i>\n        </div>\n        <span class=\"text-xl font-bold tracking-tight glow-blue\" data-kid=\"50\">MATCH<span class=\"font-light text-[var(--accent-blue)]\" data-kid=\"51\">PREDICTOR</span></span>\n      </div>\n      \n      <div class=\"hidden lg:flex items-center space-x-6 text-sm font-medium uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"52\">\n        <a href=\"#\" class=\"text-[var(--text-primary)] border-b-2 border-[var(--accent-blue)] pb-1 transition-colors\" data-kid=\"53\">Predictions</a>\n        <a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"54\">Analytics</a>\n        <a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"55\">Models</a>\n        <a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"56\">Leagues</a>\n      </div>\n    </div>\n\n    <div class=\"flex items-center space-x-4\" data-kid=\"57\">\n      <div class=\"relative\" data-kid=\"58\">\n        <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-secondary)]\" data-kid=\"59\"></i>\n        <input type=\"text\" placeholder=\"FIND MATCH OR TEAM...\" class=\"bg-[var(--bg-alt)] border border-[var(--border)] pl-10 pr-4 py-1.5 text-xs font-mono rounded-sm focus:outline-none focus:border-[var(--accent-blue)] transition-all w-64 placeholder:opacity-50\" data-kid=\"60\">\n      </div>\n      <button class=\"bg-[var(--accent-blue)] hover:bg-blue-600 text-black px-4 py-1.5 rounded-sm text-xs font-bold transition-all uppercase tracking-tighter\" data-kid=\"61\">\n        Live Monitor\n      </button>\n    </div>\n  </nav>\n\n  <main class=\"p-6 max-w-[1600px] mx-auto\" data-kid=\"62\">\n    \n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-8\" data-kid=\"63\">\n      \n      <div class=\"bg-[var(--bg-card)] border border-[var(--border)] p-4 relative overflow-hidden group hover:border-[var(--accent-blue)] transition-all\" data-kid=\"64\">\n        <div class=\"flex justify-between items-start mb-2\" data-kid=\"65\">\n          <span class=\"text-[10px] uppercase font-bold tracking-widest text-[var(--text-secondary)]\" data-kid=\"66\">Model Accuracy</span>\n          <span class=\"text-[var(--accent-green)] text-xs font-mono font-bold\" data-kid=\"67\">+2.4%</span>\n        </div>\n        <div class=\"text-2xl font-mono font-bold glow-green\" data-kid=\"68\">78.4%</div>\n        <div class=\"h-10 mt-2\" data-kid=\"69\">\n          <canvas id=\"chart-accuracy\" data-kid=\"70\"></canvas>\n        </div>\n      </div>\n\n      <div class=\"bg-[var(--bg-card)] border border-[var(--border)] p-4 relative overflow-hidden group hover:border-[var(--accent-blue)] transition-all\" data-kid=\"71\">\n        <div class=\"flex justify-between items-start mb-2\" data-kid=\"72\">\n          <span class=\"text-[10px] uppercase font-bold tracking-widest text-[var(--text-secondary)]\" data-kid=\"73\">Global ROI</span>\n          <span class=\"text-[var(--accent-green)] text-xs font-mono font-bold\" data-kid=\"74\">+12.8%</span>\n        </div>\n        <div class=\"text-2xl font-mono font-bold glow-green\" data-kid=\"75\">14.2%</div>\n        <div class=\"h-10 mt-2\" data-kid=\"76\">\n          <canvas id=\"chart-roi\" data-kid=\"77\"></canvas>\n        </div>\n      </div>\n\n      <div class=\"bg-[var(--bg-card)] border border-[var(--border)] p-4 relative overflow-hidden group hover:border-[var(--accent-blue)] transition-all\" data-kid=\"78\">\n        <div class=\"flex justify-between items-start mb-2\" data-kid=\"79\">\n          <span class=\"text-[10px] uppercase font-bold tracking-widest text-[var(--text-secondary)]\" data-kid=\"80\">Confidence Hit</span>\n          <span class=\"text-[var(--accent-yellow)] text-xs font-mono font-bold\" data-kid=\"81\">-0.5%</span>\n        </div>\n        <div class=\"text-2xl font-mono font-bold glow-yellow\" data-kid=\"82\">92.1%</div>\n        <div class=\"h-10 mt-2\" data-kid=\"83\">\n          <canvas id=\"chart-confidence\" data-kid=\"84\"></canvas>\n        </div>\n      </div>\n\n      <div class=\"bg-[var(--bg-card)] border border-[var(--border)] p-4 relative overflow-hidden group hover:border-[var(--accent-blue)] transition-all\" data-kid=\"85\">\n        <div class=\"flex justify-between items-start mb-2\" data-kid=\"86\">\n          <span class=\"text-[10px] uppercase font-bold tracking-widest text-[var(--text-secondary)]\" data-kid=\"87\">Active Signals</span>\n          <i class=\"ti ti-activity text-[var(--accent-blue)]\" data-kid=\"88\"></i>\n        </div>\n        <div class=\"text-2xl font-mono font-bold glow-blue\" data-kid=\"89\">14</div>\n        <div class=\"h-10 mt-2\" data-kid=\"90\">\n          <canvas id=\"chart-signals\" data-kid=\"91\"></canvas>\n        </div>\n      </div>\n\n      \n      <div class=\"bg-gradient-to-br from-[#1a202c] to-[#0a0c0f] border border-[var(--accent-blue)] p-4 relative overflow-hidden shadow-[0_0_20px_rgba(58,160,255,0.1)]\" data-kid=\"92\">\n        <div class=\"absolute -right-4 -top-4 w-24 h-24 bg-[var(--accent-blue)]/5 rounded-full blur-2xl\" data-kid=\"93\"></div>\n        <div class=\"flex justify-between items-start mb-1\" data-kid=\"94\">\n          <span class=\"text-[10px] uppercase font-bold tracking-widest text-[var(--accent-blue)]\" data-kid=\"95\">Match of the Day</span>\n          <span class=\"bg-[var(--accent-blue)] text-black text-[9px] font-bold px-1.5 rounded-sm\" data-kid=\"96\">TOP VALUE</span>\n        </div>\n        <div class=\"text-sm font-bold mb-1 truncate\" data-kid=\"97\">MAN CITY vs LIVERPOOL</div>\n        <div class=\"flex items-end justify-between\" data-kid=\"98\">\n          <div class=\"text-xl font-mono font-bold text-[var(--accent-green)]\" data-kid=\"99\">1 (1.85)</div>\n          <div class=\"text-[10px] font-mono text-[var(--text-secondary)]\" data-kid=\"100\">CONF: 94%</div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex flex-col lg:flex-row gap-6\" data-kid=\"101\">\n      \n      \n      <div class=\"flex-grow\" data-kid=\"102\">\n        <div class=\"flex items-center justify-between mb-4\" data-kid=\"103\">\n          <h2 class=\"text-xs uppercase font-bold tracking-[0.2em] text-[var(--text-secondary)] flex items-center space-x-2\" data-kid=\"104\">\n            <span class=\"w-1 h-3 bg-[var(--accent-blue)]\" data-kid=\"105\"></span>\n            <span data-kid=\"106\">Market Liquidity & Probabilities</span>\n          </h2>\n          <div class=\"flex space-x-2\" data-kid=\"107\">\n            <button class=\"bg-[var(--bg-card)] border border-[var(--border)] px-3 py-1 text-[10px] font-mono uppercase hover:border-[var(--accent-blue)] transition-all\" data-kid=\"108\">Today</button>\n            <button class=\"bg-[var(--bg-card)] border border-[var(--border)] px-3 py-1 text-[10px] font-mono uppercase hover:border-[var(--accent-blue)] transition-all\" data-kid=\"109\">Tomorrow</button>\n          </div>\n        </div>\n\n        <div class=\"bg-[var(--bg-card)] border border-[var(--border)] rounded-sm overflow-hidden\" data-kid=\"110\">\n          <table class=\"w-full text-left border-collapse font-mono text-[11px]\" data-kid=\"111\">\n            <thead class=\"bg-black/40 text-[var(--text-secondary)] uppercase tracking-wider\" data-kid=\"112\">\n              <tr data-kid=\"113\">\n                <th class=\"px-4 py-3 border-b border-[var(--border)] w-16\" data-kid=\"114\">TIME</th>\n                <th class=\"px-4 py-3 border-b border-[var(--border)]\" data-kid=\"115\">MATCHUP</th>\n                <th class=\"px-4 py-3 border-b border-[var(--border)] text-center w-48\" data-kid=\"116\">1 X 2 PROBABILITY</th>\n                <th class=\"px-4 py-3 border-b border-[var(--border)] text-center w-24\" data-kid=\"117\">O/U 2.5</th>\n                <th class=\"px-4 py-3 border-b border-[var(--border)] text-center w-16\" data-kid=\"118\">BTTS</th>\n                <th class=\"px-4 py-3 border-b border-[var(--border)] text-center w-24\" data-kid=\"119\">VALUE</th>\n                <th class=\"px-4 py-3 border-b border-[var(--border)] w-10\" data-kid=\"120\"></th>\n              </tr>\n            </thead>\n            <tbody class=\"divide-y divide-[var(--border)]/30\" data-kid=\"121\">\n              \n              <tr class=\"bg-[#0a0c0f] hover:bg-blue-900/10 group transition-all cursor-pointer\" data-kid=\"122\">\n                <td class=\"px-4 py-4 text-[var(--text-secondary)]\" data-kid=\"123\">20:00</td>\n                <td class=\"px-4 py-4\" data-kid=\"124\">\n                  <div class=\"flex flex-col\" data-kid=\"125\">\n                    <span class=\"font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-blue)] transition-colors\" data-kid=\"126\">REAL MADRID</span>\n                    <span class=\"font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-blue)] transition-colors\" data-kid=\"127\">FC BARCELONA</span>\n                  </div>\n                </td>\n                <td class=\"px-4 py-4\" data-kid=\"128\">\n        