te/30 hover:text-white transition-colors\" data-kid=\"195\">\n    <i class=\"ti ti-calendar text-xl\" data-kid=\"196\"></i>\n    <span class=\"text-[8px] font-bold uppercase tracking-widest\" data-kid=\"197\">Fixtures</span>\n  </button>\n  <button class=\"flex flex-col items-center gap-1 text-white/30 hover:text-white transition-colors\" data-kid=\"198\">\n    <i class=\"ti ti-user text-xl\" data-kid=\"199\"></i>\n    <span class=\"text-[8px] font-bold uppercase tracking-widest\" data-kid=\"200\">Profile</span>\n  </button>\n</nav>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"201\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"202\"></script>\n<script type=\"module\" data-kid=\"203\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  const lenis = new Lenis()\n  function raf(time) {\n    lenis.raf(time)\n    requestAnimationFrame(raf)\n  }\n  requestAnimationFrame(raf)\n\n  // Initialize Charts\n  const ctxGauge = document.getElementById('heroGauge').getContext('2d');\n  new Chart(ctxGauge, {\n    type: 'doughnut',\n    data: {\n      datasets: [{\n        data: [72, 28],\n        backgroundColor: ['#4f95d6', 'rgba(255,255,255,0.05)'],\n        borderWidth: 0,\n        circumference: 270,\n        rotation: 225,\n        borderRadius: 10,\n        cutout: '85%'\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: { legend: { display: false }, tooltip: { enabled: false } }\n    }\n  });\n\n  const ctxMarket = document.getElementById('marketChart').getContext('2d');\n  const gradient = ctxMarket.createLinearGradient(0, 0, 0, 200);\n  gradient.addColorStop(0, 'rgba(79, 149, 214, 0.3)');\n  gradient.addColorStop(1, 'rgba(79, 149, 214, 0)');\n\n  new Chart(ctxMarket, {\n    type: 'line',\n    data: {\n      labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],\n      datasets: [\n        {\n          label: 'Model',\n          data: [65, 78, 72, 85, 82, 90, 88],\n          borderColor: '#4f95d6',\n          backgroundColor: gradient,\n          fill: true,\n          tension: 0.4,\n          pointRadius: 0\n        },\n        {\n          label: 'Market',\n          data: [60, 65, 70, 75, 72, 78, 80],\n          borderColor: 'rgba(255,255,255,0.2)',\n          borderDash: [5, 5],\n          tension: 0.4,\n          pointRadius: 0\n        }\n      ]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: { legend: { display: false } },\n      scales: {\n        x: { display: false },\n        y: { display: false }\n      }\n    }\n  });\n\n  // GSAP Animations\n  gsap.from(\"header\", { opacity: 0, y: -20, duration: 1, ease: \"power4.out\" });\n  gsap.from(\"#hero-prediction\", { opacity: 0, y: 30, duration: 1.2, delay: 0.2, ease: \"power4.out\" });\n  gsap.from(\".carousel-hide-scrollbar > div\", { \n    opacity: 0, \n    x: 40, \n    stagger: 0.1, \n    duration: 1, \n    delay: 0.4, \n    ease: \"power4.out\" \n  });\n  gsap.from(\".grid > div\", { \n    opacity: 0, \n    y: 20, \n    stagger: 0.1, \n    duration: 1, \n    delay: 0.6, \n    ease: \"power4.out\" \n  });\n  gsap.from(\".floating-dock\", { opacity: 0, y: 50, duration: 1.5, delay: 1, ease: \"elastic.out(1, 0.75)\" });\n</script></main>",
