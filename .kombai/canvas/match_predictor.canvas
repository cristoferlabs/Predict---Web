             </td>\n                <td class=\"px-4 py-4 text-center\" data-kid=\"192\">\n                  <span class=\"text-[var(--accent-green)]\" data-kid=\"193\">YES</span>\n                </td>\n                <td class=\"px-4 py-4 text-center\" data-kid=\"194\">\n                  <span class=\"text-[var(--accent-yellow)] font-bold shadow-[0_0_8px_var(--accent-yellow)/30]\" data-kid=\"195\">7.2</span>\n                </td>\n                <td class=\"px-4 py-4 text-center\" data-kid=\"196\">\n                  <i class=\"ti ti-chevron-right text-[var(--text-secondary)] opacity-0 group-hover:opacity-100 transition-all\" data-kid=\"197\"></i>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      \n      <aside class=\"w-full lg:w-96 shrink-0 space-y-6\" data-kid=\"198\">\n        <div class=\"bg-[var(--bg-card)] border border-[var(--border)] p-6 sticky top-28\" data-kid=\"199\">\n          <div class=\"flex items-center justify-between mb-6\" data-kid=\"200\">\n            <h3 class=\"text-xs font-bold uppercase tracking-widest text-[var(--accent-blue)]\" data-kid=\"201\">Deep Analysis</h3>\n            <span class=\"text-[10px] font-mono text-[var(--text-secondary)]\" data-kid=\"202\">ID: #M-90231</span>\n          </div>\n\n          \n          <div class=\"relative w-full aspect-square mb-6 bg-black/40 border border-[var(--border)] flex items-center justify-center overflow-hidden\" data-kid=\"203\">\n            <div class=\"absolute inset-0 opacity-10\" style=\"background-image: radial-gradient(var(--border) 1px, transparent 1px); background-size: 20px 20px;\" data-kid=\"204\"></div>\n            <canvas id=\"radar-chart\" data-kid=\"205\"></canvas>\n          </div>\n\n          \n          <div class=\"space-y-4 font-mono\" data-kid=\"206\">\n            <div class=\"flex justify-between items-center text-[10px]\" data-kid=\"207\">\n              <span class=\"text-[var(--text-secondary)]\" data-kid=\"208\">MODEL CONFIDENCE:</span>\n              <span class=\"text-[var(--accent-green)] font-bold\" data-kid=\"209\">HIGH (94.2%)</span>\n            </div>\n            <div class=\"flex justify-between items-center text-[10px]\" data-kid=\"210\">\n              <span class=\"text-[var(--text-secondary)]\" data-kid=\"211\">HISTORICAL HIT RATE:</span>\n              <span class=\"text-[var(--text-primary)]\" data-kid=\"212\">82.1%</span>\n            </div>\n            <div class=\"flex justify-between items-center text-[10px]\" data-kid=\"213\">\n              <span class=\"text-[var(--text-secondary)]\" data-kid=\"214\">ELO DELTA:</span>\n              <span class=\"text-[var(--accent-blue)]\" data-kid=\"215\">+142</span>\n            </div>\n          </div>\n\n          <hr class=\"my-6 border-[var(--border)]\" data-kid=\"216\">\n\n          <div class=\"space-y-3\" data-kid=\"217\">\n            <h4 class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--text-secondary)] mb-4\" data-kid=\"218\">Top Value Bets</h4>\n            <div class=\"bg-[var(--bg-main)] p-3 border-l-2 border-[var(--accent-green)] group hover:bg-green-500/5 transition-all cursor-pointer\" data-kid=\"219\">\n              <div class=\"flex justify-between items-center mb-1\" data-kid=\"220\">\n                <span class=\"text-xs font-bold\" data-kid=\"221\">Home Win (1X2)</span>\n                <span class=\"text-xs font-mono text-[var(--accent-green)]\" data-kid=\"222\">1.85</span>\n              </div>\n              <div class=\"w-full bg-[var(--border)] h-1.5 rounded-full overflow-hidden\" data-kid=\"223\">\n                <div class=\"bg-[var(--accent-green)] h-full\" style=\"width: 85%;\" data-kid=\"224\"></div>\n              </div>\n            </div>\n\n            <div class=\"bg-[var(--bg-main)] p-3 border-l-2 border-[var(--accent-blue)] group hover:bg-blue-500/5 transition-all cursor-pointer\" data-kid=\"225\">\n              <div class=\"flex justify-between items-center mb-1\" data-kid=\"226\">\n                <span class=\"text-xs font-bold\" data-kid=\"227\">Over 2.5 Goals</span>\n                <span class=\"text-xs font-mono text-[var(--accent-blue)]\" data-kid=\"228\">1.65</span>\n              </div>\n              <div class=\"w-full bg-[var(--border)] h-1.5 rounded-full overflow-hidden\" data-kid=\"229\">\n                <div class=\"bg-[var(--accent-blue)] h-full\" style=\"width: 72%;\" data-kid=\"230\"></div>\n              </div>\n            </div>\n\n            <div class=\"bg-[var(--bg-main)] p-3 border-l-2 border-[var(--accent-yellow)] group hover:bg-yellow-500/5 transition-all cursor-pointer\" data-kid=\"231\">\n              <div class=\"flex justify-between items-center mb-1\" data-kid=\"232\">\n                <span class=\"text-xs font-bold\" data-kid=\"233\">Both Teams to Score</span>\n                <span class=\"text-xs font-mono text-[var(--accent-yellow)]\" data-kid=\"234\">1.72</span>\n              </div>\n              <div class=\"w-full bg-[var(--border)] h-1.5 rounded-full overflow-hidden\" data-kid=\"235\">\n                <div class=\"bg-[var(--accent-yellow)] h-full\" style=\"width: 65%;\" data-kid=\"236\"></div>\n              </div>\n            </div>\n          </div>\n\n          <button class=\"w-full mt-6 bg-[var(--bg-alt)] border border-[var(--accent-blue)] text-[var(--accent-blue)] hover:bg-[var(--accent-blue)] hover:text-black font-bold py-3 text-xs uppercase tracking-widest transition-all\" data-kid=\"237\">\n            Full Match Report\n          </button>\n        </div>\n      </aside>\n\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"238\"></script>\n<script data-kid=\"239\">\n  const chartOptions = {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: { legend: { display: false } },\n    scales: { x: { display: false }, y: { display: false } },\n    elements: {\n      line: { tension: 0.4, borderWidth: 2, fill: true },\n      point: { radius: 0 }\n    }\n  };\n\n  const createSparkline = (id, data, color) => {\n    const ctx = document.getElementById(id).getContext('2d');\n    new Chart(ctx, {\n      type: 'line',\n      data: {\n        labels: data.map((_, i) => i),\n        datasets: [{\n          data: data,\n          borderColor: color,\n          backgroundColor: color + '10',\n        }]\n      },\n      options: chartOptions\n    });\n  };\n\n  window.onload = () => {\n    createSparkline('chart-accuracy', [75, 76, 74, 77, 78, 77.5, 78.4], '#34d399');\n    createSparkline('chart-roi', [10, 12, 11, 13, 15, 13.5, 14.2], '#34d399');\n    createSparkline('chart-confidence', [95, 94, 93, 94, 93.5, 92.5, 92.1], '#fbbf24');\n    createSparkline('chart-signals', [8, 10, 12, 11, 14, 13, 14], '#3aa0ff');\n\n    // Radar Chart\n    const radarCtx = document.getElementById('radar-chart').getContext('2d');\n    new Chart(radarCtx, {\n      type: 'radar',\n      data: {\n        labels: ['ATT', 'DEF', 'POSS', 'ELO', 'FORM', 'XG'],\n        datasets: [{\n          label: 'Real Madrid',\n          data: [90, 85, 88, 92, 95, 89],\n          borderColor: '#3aa0ff',\n          backgroundColor: 'rgba(58, 160, 255, 0.2)',\n          borderWidth: 2\n        }, {\n          label: 'FC Barcelona',\n          data: [88, 82, 92, 89, 87, 91],\n          borderColor: '#f87171',\n          backgroundColor: 'rgba(248, 113, 113, 0.2)',\n          borderWidth: 2\n        }]\n      },\n      options: {\n        plugins: { legend: { display: false } },\n        scales: {\n          r: {\n            angleLines: { color: '#232830' },\n            grid: { color: '#232830' },\n            pointLabels: { color: '#94a3b8', font: { size: 9, family: 'IBM Plex Mono' } },\n            ticks: { display: false }\n          }\n        }\n      }\n    });\n  };\n</script>",
